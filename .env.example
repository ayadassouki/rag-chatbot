# === OpenAI API Key (required) ===
# Replace with your own OpenAI key when running locally or in Docker
OPENAI_API_KEY=your-openai-api-key-here

# === Session Config ===
# Auto-purges session after X minutes of inactivity
SESSION_TIMEOUT_MINUTES=30

# === Developer Mode ===
# Set True for verbose logging / exception traces in the UI
DEV_MODE=False
